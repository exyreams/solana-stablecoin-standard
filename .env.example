# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com
SOLANA_KEYPAIR_PATH=~/.config/solana/id.json

# Program IDs (update after deploy)
SSS_TOKEN_PROGRAM_ID=SSSTokenXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TRANSFER_HOOK_PROGRAM_ID=HookXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Mint (update after init)
STABLECOIN_MINT=

# Services
PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# Webhooks
WEBHOOK_SECRET=change-me-in-production
WEBHOOK_RETRY_ATTEMPTS=3

# Database (event-indexer)
DATABASE_URL=sqlite:./data/events.db
